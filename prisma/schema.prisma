generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                @id @default(uuid())
  phone            String                @unique
  firstName        String?
  lastName         String?
  email            String?               @unique
  avatarUrl        String?
  referralCode     String?               @unique
  referredBy       String?
  fcmToken         String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  role             UserRole              @default(USER)
  userType         UserType?
  bins             Bin[]
  collectorProfile CollectorProfile?
  ecoPointTx       EcoPointTransaction[]
  notifications    Notification[]
  payments         Payment[]
  pickups          Pickup[]              @relation("UserPickups")
  refreshTokens    RefreshToken[]
  referrer         User?                 @relation("UserReferral", fields: [referredBy], references: [id])
  referrals        User[]                @relation("UserReferral")
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model EcoPointTransaction {
  id          String   @id @default(uuid())
  points      Int
  action      String
  description String?
  createdAt   DateTime @default(now())
  userId      String
  pickupId    String?
  pickup      Pickup?  @relation(fields: [pickupId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Bin {
  id            String    @id @default(uuid())
  qrCode        String    @unique
  fillLevel     Int       @default(0)
  reportedIssue String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        String
  wasteType     WasteType
  lastEmptied   DateTime?
  latitude      Float?
  longitude     Float?
  status        BinStatus @default(ACTIVE)
  user          User      @relation(fields: [userId], references: [id])
  pickups       Pickup[]
}

model Pickup {
  id            String                @id @default(uuid())
  scheduledDate DateTime
  address       String
  latitude      Float
  longitude     Float
  notes         String?
  weightKg      Float?
  cancelReason  String?
  userId        String
  collectorId   String?
  binId         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  reference     String                @unique
  wasteType     WasteType
  status        PickupStatus          @default(PENDING)
  cancelledAt   DateTime?
  completedAt   DateTime?
  timeSlot      TimeSlot
  ecoPointTx    EcoPointTransaction[]
  payment       Payment?
  bin           Bin?                  @relation(fields: [binId], references: [id])
  collector     CollectorProfile?     @relation("CollectorPickups", fields: [collectorId], references: [id])
  user          User                  @relation("UserPickups", fields: [userId], references: [id])
}

model Payment {
  id             String        @id @default(uuid())
  amount         Float
  pickupId       String        @unique
  userId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  currency       String        @default("RWF")
  externalRef    String?
  paidAt         DateTime?
  transactionRef String        @unique
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  pickup         Pickup        @relation(fields: [pickupId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Notification {
  id     String           @id @default(uuid())
  type   NotificationType @default(IN_APP)
  title  String
  body   String
  data   Json?
  isRead Boolean          @default(false)
  sentAt DateTime         @default(now())
  userId String
  user   User             @relation(fields: [userId], references: [id])
}

model CollectorProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  vehiclePlate String
  zone         String
  latitude     Float?
  longitude    Float?
  photoUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  rating       Float    @default(5.0)
  totalPickups Int      @default(0)
  isAvailable  Boolean  @default(true)
  user         User     @relation(fields: [userId], references: [id])
  pickups      Pickup[] @relation("CollectorPickups")
}

enum UserRole {
  USER
  COLLECTOR
  ADMIN
}

enum UserType {
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  BUSINESS
}

enum NotificationType {
  IN_APP
  SMS
  PUSH
  EMAIL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
}

enum WasteType {
  ORGANIC
  RECYCLABLE
  EWASTE
  GENERAL
  GLASS
  HAZARDOUS
}

enum PickupStatus {
  PENDING
  CONFIRMED
  COLLECTOR_ASSIGNED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TimeSlot {
  MORNING_8_10
  MORNING_10_12
  AFTERNOON_12_2
  AFTERNOON_2_4
  EVENING_4_6
}

enum BinStatus {
  ACTIVE
  FULL
  INACTIVE
  MAINTENANCE
}
