// ─── Generator ─────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

// ─── Datasource ─────────────────────────────────────
datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────

enum UserRole {
  USER
  COLLECTOR
  ADMIN
}

enum UserType {
  RESIDENTIAL
  BUSINESS
  COMMERCIAL
  INDUSTRIAL
}

enum NotificationType {
  IN_APP
  SMS
  PUSH
  EMAIL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
}

enum WasteType {
  ORGANIC
  RECYCLABLE
  EWASTE
  GENERAL
  GLASS
  HAZARDOUS
}

enum PickupStatus {
  PENDING
  CONFIRMED
  COLLECTOR_ASSIGNED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TimeSlot {
  MORNING_8_10
  MORNING_10_12
  AFTERNOON_12_2
  AFTERNOON_2_4
  EVENING_4_6
}

enum BinStatus {
  ACTIVE
  FULL
  INACTIVE
  MAINTENANCE
}

// ─── Models ────────────────────────────────────────

model User {
  id                  String                @id @default(uuid())
  phone               String                @unique
  firstName           String?
  lastName            String?
  email               String?               @unique
  userType            UserType?
  role                UserRole              @default(USER)
  avatarUrl           String?
  referralCode        String?               @unique
  referredBy          String?
  fcmToken            String?
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  refreshTokens       RefreshToken[]
  ecoPointTx          EcoPointTransaction[]
  bins                Bin[]
  pickups             Pickup[]              @relation("UserPickups")
  payments            Payment[]
  notifications       Notification[]
  collectorProfile    CollectorProfile?
  
  referrals           User[]                @relation("UserReferral")
  referrer            User?                 @relation("UserReferral", fields: [referredBy], references: [id])
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model EcoPointTransaction {
  id          String   @id @default(uuid())
  points      Int
  action      String
  description String?
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  pickupId    String?
  pickup      Pickup?  @relation(fields: [pickupId], references: [id])
}

model Bin {
  id            String    @id @default(uuid())
  wasteType     WasteType
  qrCode        String    @unique
  fillLevel     Int       @default(0)
  status        BinStatus @default(ACTIVE)
  reportedIssue String?
  notes         String?
  latitude      Float?
  longitude     Float?
  lastEmptied   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  pickups       Pickup[]
}

model Pickup {
  id            String       @id @default(uuid())
  reference     String       @unique
  wasteType     WasteType
  weightKg      Float?
  scheduledDate DateTime
  timeSlot      TimeSlot
  address       String
  latitude      Float
  longitude     Float
  notes         String?
  status        PickupStatus @default(PENDING)
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  userId        String
  user          User         @relation("UserPickups", fields: [userId], references: [id])
  
  collectorId   String?
  collector     CollectorProfile? @relation("CollectorPickups", fields: [collectorId], references: [id])
  
  binId         String?
  bin           Bin?         @relation(fields: [binId], references: [id])
  
  payment       Payment?
  ecoPointTx    EcoPointTransaction[]
}

model Payment {
  id             String        @id @default(uuid())
  transactionRef String        @unique
  externalRef    String?
  amount         Float
  currency       String        @default("RWF")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  pickupId       String        @unique
  pickup         Pickup        @relation(fields: [pickupId], references: [id])
  
  userId         String
  user           User          @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType @default(IN_APP)
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  sentAt    DateTime         @default(now())
  
  userId    String
  user      User             @relation(fields: [userId], references: [id])
}

model CollectorProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  vehiclePlate String
  zone         String
  latitude     Float?
  longitude    Float?
  photoUrl     String?
  rating       Float    @default(5.0)
  totalPickups Int      @default(0)
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  pickups      Pickup[] @relation("CollectorPickups")
}
