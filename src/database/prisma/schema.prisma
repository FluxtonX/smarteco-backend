generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────

enum UserType {
  RESIDENTIAL
  BUSINESS
}

enum UserRole {
  USER
  COLLECTOR
  ADMIN
}

enum WasteType {
  ORGANIC
  RECYCLABLE
  GENERAL
  EWASTE
  GLASS
  HAZARDOUS
}

enum PickupStatus {
  PENDING
  CONFIRMED
  COLLECTOR_ASSIGNED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TimeSlot {
  MORNING_8_10
  MORNING_10_12
  AFTERNOON_2_4
  AFTERNOON_4_6
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum EcoTier {
  ECO_STARTER
  ECO_WARRIOR
  ECO_CHAMPION
}

enum NotificationType {
  SMS
  PUSH
  IN_APP
  WHATSAPP
}

enum BinStatus {
  ACTIVE
  FULL
  MAINTENANCE
  INACTIVE
}

// ─── MODELS ──────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  email        String?  @unique
  firstName    String?
  lastName     String?
  userType     UserType @default(RESIDENTIAL)
  role         UserRole @default(USER)
  referralCode String   @unique
  referredBy   String?
  avatarUrl    String?
  fcmToken     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  pickups          Pickup[]
  bins             Bin[]
  ecoPoints        EcoPointTransaction[]
  payments         Payment[]
  notifications    Notification[]
  referredUsers    User[]             @relation("Referrals")
  referrer         User?              @relation("Referrals", fields: [referredBy], references: [id])
  collectorProfile CollectorProfile?
  refreshTokens    RefreshToken[]

  @@map("User")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("RefreshToken")
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, otp])
  @@index([phone, createdAt])
  @@map("OtpVerification")
}

model CollectorProfile {
  id            String    @id @default(uuid())
  userId        String    @unique
  collectorName String?
  vehiclePlate  String
  zone          String
  photoUrl      String?
  rating        Float     @default(0.0)
  totalPickups  Int       @default(0)
  isAvailable   Boolean   @default(true)
  isApproved    Boolean   @default(false)
  approvedAt    DateTime?
  approvedBy    String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickups Pickup[]

  @@map("CollectorProfile")
}

model Pickup {
  id            String       @id @default(uuid())
  reference     String       @unique
  userId        String
  collectorId   String?
  wasteType     WasteType
  weightKg      Float?
  scheduledDate DateTime
  timeSlot      TimeSlot
  status        PickupStatus @default(PENDING)
  address       String
  latitude      Float
  longitude     Float
  notes         String?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  user      User              @relation(fields: [userId], references: [id])
  collector CollectorProfile? @relation(fields: [collectorId], references: [id])
  payment   Payment?
  bin       Bin?              @relation(fields: [binId], references: [id])
  binId     String?

  @@index([userId])
  @@index([collectorId])
  @@index([status])
  @@index([scheduledDate])
  @@index([reference])
  @@map("Pickup")
}

model Bin {
  id          String    @id @default(uuid())
  qrCode      String    @unique
  userId      String
  wasteType   WasteType
  fillLevel   Int       @default(0)
  status      BinStatus @default(ACTIVE)
  latitude    Float?
  longitude   Float?
  lastEmptied DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickups Pickup[]

  @@index([userId])
  @@index([qrCode])
  @@map("Bin")
}

model EcoPointTransaction {
  id          String   @id @default(uuid())
  userId      String
  points      Int
  action      String
  description String?
  pickupId    String?
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("EcoPointTransaction")
}

model Payment {
  id             String        @id @default(uuid())
  pickupId       String        @unique
  userId         String
  amount         Float
  currency       String        @default("RWF")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionRef String?       @unique
  externalRef    String?
  paidAt         DateTime?
  failedAt       DateTime?
  failReason     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  pickup Pickup @relation(fields: [pickupId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([transactionRef])
  @@map("Payment")
}

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean          @default(false)
  sentAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([sentAt])
  @@map("Notification")
}
