generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────

enum UserType {
  RESIDENTIAL
  BUSINESS
}

enum UserRole {
  USER
  COLLECTOR
  ADMIN
}

enum WasteType {
  ORGANIC
  RECYCLABLE
  GENERAL
  EWASTE
  GLASS
  HAZARDOUS
}

enum PickupStatus {
  PENDING
  CONFIRMED
  COLLECTOR_ASSIGNED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TimeSlot {
  MORNING_8_10
  MORNING_10_12
  AFTERNOON_2_4
  AFTERNOON_4_6
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum EcoTier {
  ECO_STARTER
  ECO_WARRIOR
  ECO_CHAMPION
}

enum NotificationType {
  SMS
  PUSH
  IN_APP
  WHATSAPP
}

enum BinStatus {
  ACTIVE
  FULL
  MAINTENANCE
  INACTIVE
}

enum IotDeviceStatus {
  ONLINE
  OFFLINE
  WARNING
  MAINTENANCE
}

enum CommunicationChannel {
  SMS
  WHATSAPP
  USSD
  PUSH
  IN_APP
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum CommunicationStatus {
  RECEIVED
  SENT
  QUEUED
  FAILED
}

enum RedemptionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum SupportDisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum SupportDisputePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AuditStatus {
  SUCCESS
  FAILED
  PENDING
}

// ─── MODELS ──────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  phone          String   @unique
  email          String?  @unique
  firstName      String?
  lastName       String?
  userType       UserType @default(RESIDENTIAL)
  role           UserRole @default(USER)
  referralCode   String?  @unique
  referredBy     String?
  avatarUrl      String?
  fcmToken       String?
  defaultAddress String?
  homeLatitude   Float?
  homeLongitude  Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  // Relations
  pickups          Pickup[]
  bins             Bin[]
  ecoPoints        EcoPointTransaction[]
  payments         Payment[]
  notifications    Notification[]
  iotDevices       IotDevice[]
  redemptions      Redemption[]
  supportDisputes  SupportDispute[]
  auditLogs        AuditLog[]            @relation("AuditActor")
  referredUsers    User[]                @relation("Referrals")
  referrer         User?                 @relation("Referrals", fields: [referredBy], references: [id])
  collectorProfile CollectorProfile?
  refreshTokens    RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, otp])
  @@index([phone, createdAt])
  @@map("otp_verifications")
}

model CollectorProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  collectorName      String?
  vehiclePlate       String
  zone               String
  zonePolygon        Json?
  photoUrl           String?
  licenseDocumentUrl String?
  licenseDocumentKey String?
  idDocumentUrl      String?
  idDocumentKey      String?
  rating             Float     @default(0.0)
  totalPickups       Int       @default(0)
  isAvailable        Boolean   @default(true)
  isApproved         Boolean   @default(false)
  approvedAt         DateTime?
  approvedBy         String?
  latitude           Float?
  longitude          Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickups Pickup[]

  @@map("collector_profiles")
}

model Pickup {
  id            String       @id @default(uuid())
  reference     String       @unique
  userId        String
  collectorId   String?
  wasteType     WasteType
  weightKg      Float?
  scheduledDate DateTime
  timeSlot      TimeSlot
  status        PickupStatus @default(PENDING)
  address       String
  latitude      Float
  longitude     Float
  notes         String?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt

  // Relations
  user      User              @relation(fields: [userId], references: [id])
  collector CollectorProfile? @relation(fields: [collectorId], references: [id])
  payment   Payment?
  bin       Bin?              @relation(fields: [binId], references: [id])
  binId     String?

  @@index([userId])
  @@index([collectorId])
  @@index([status])
  @@index([scheduledDate])
  @@index([reference])
  @@map("pickups")
}

model Bin {
  id          String    @id @default(uuid())
  qrCode      String    @unique
  userId      String
  wasteType   WasteType
  fillLevel   Int       @default(0)
  status      BinStatus @default(ACTIVE)
  latitude    Float?
  longitude   Float?
  lastEmptied DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  // Relations
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pickups        Pickup[]
  iotDevice      IotDevice?
  iotTelemetries IotTelemetry[]

  @@index([userId])
  @@index([qrCode])
  @@map("bins")
}

model IotDevice {
  id           String          @id @default(uuid())
  deviceId     String          @unique
  binId        String          @unique
  userId       String
  status       IotDeviceStatus @default(OFFLINE)
  firmware     String?
  batteryLevel Int?
  signalRssi   Float?
  lastSeenAt   DateTime?
  registeredAt DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt

  bin       Bin            @relation(fields: [binId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  telemetry IotTelemetry[]

  @@index([userId])
  @@index([status])
  @@index([lastSeenAt])
  @@map("iot_devices")
}

model IotTelemetry {
  id           String   @id @default(uuid())
  deviceId     String?
  binId        String
  fillLevel    Int
  batteryLevel Int?
  signalRssi   Float?
  latitude     Float?
  longitude    Float?
  rawPayload   Json?
  receivedAt   DateTime @default(now())

  device IotDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  bin    Bin        @relation(fields: [binId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([binId])
  @@index([receivedAt])
  @@map("iot_telemetry")
}

model EcoPointTransaction {
  id          String   @id @default(uuid())
  userId      String
  points      Int
  action      String
  description String?
  pickupId    String?
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("eco_point_transactions")
}

model Payment {
  id             String        @id @default(uuid())
  pickupId       String        @unique
  userId         String
  amount         Float
  currency       String        @default("RWF")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionRef String?       @unique
  externalRef    String?
  paidAt         DateTime?
  failedAt       DateTime?
  failReason     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt

  // Relations
  pickup      Pickup              @relation(fields: [pickupId], references: [id])
  user        User                @relation(fields: [userId], references: [id])
  webhookLogs PaymentWebhookLog[]

  @@index([userId])
  @@index([status])
  @@index([transactionRef])
  @@map("payments")
}

model PaymentWebhookLog {
  id             String         @id @default(uuid())
  paymentId      String?
  provider       PaymentMethod
  transactionRef String?
  externalRef    String?
  status         PaymentStatus?
  payload        Json
  receivedAt     DateTime       @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([provider])
  @@index([transactionRef])
  @@index([receivedAt])
  @@map("payment_webhook_logs")
}

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  title  String
  body   String
  data   Json?
  isRead Boolean          @default(false)
  sentAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([sentAt])
  @@map("notifications")
}

model CommunicationLog {
  id          String                 @id @default(uuid())
  channel     CommunicationChannel
  direction   CommunicationDirection
  status      CommunicationStatus
  phone       String?
  userId      String?
  subject     String?
  message     String
  metadata    Json?
  providerRef String?
  createdAt   DateTime               @default(now())

  @@index([channel])
  @@index([direction])
  @@index([phone])
  @@index([userId])
  @@index([createdAt])
  @@map("communication_logs")
}

model Redemption {
  id          String           @id @default(uuid())
  userId      String
  rewardId    String
  rewardLabel String
  points      Int
  status      RedemptionStatus @default(PENDING)
  provider    PaymentMethod?
  providerRef String?
  metadata    Json?
  completedAt DateTime?
  failedAt    DateTime?
  failReason  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rewardId])
  @@index([status])
  @@index([createdAt])
  @@map("redemptions")
}

model SupportDispute {
  id          String                 @id @default(uuid())
  userId      String?
  pickupId    String?
  paymentId   String?
  subject     String
  description String
  status      SupportDisputeStatus   @default(OPEN)
  priority    SupportDisputePriority @default(MEDIUM)
  assignedTo  String?
  resolution  String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @default(now()) @updatedAt
  resolvedAt  DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("support_disputes")
}

model AuditLog {
  id        String      @id @default(uuid())
  actorId   String?
  actorName String?
  module    String
  action    String
  details   String?
  status    AuditStatus @default(SUCCESS)
  metadata  Json?
  createdAt DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([module])
  @@index([status])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([key])
  @@map("system_settings")
}
